# ══════════════════════════════════════════════════════════════════════════════
# GrowEasy AI CSV Importer — Frontend Production Environment (Next.js)
# ══════════════════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_* variables are baked into the browser bundle at build time.
# Change NEXT_PUBLIC_API_URL to match your actual server host before building.

# ── API URL ────────────────────────────────────────────────────────────────────
# Docker Compose (same host, backend on port 3001):
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# If deploying on a VPS / cloud with a domain, use your domain:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# If using a reverse proxy (nginx/traefik) on the same machine at /api:
# NEXT_PUBLIC_API_URL=/api
