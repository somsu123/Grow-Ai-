# ══════════════════════════════════════════════════════════════════════════════
# GrowEasy AI CSV Importer — Docker Compose Deployment Variables
# ══════════════════════════════════════════════════════════════════════════════
# This file is read by docker-compose automatically when placed in the same
# directory as docker-compose.yml.
# Reference these in docker-compose.yml with: ${VARIABLE_NAME}
#
# Usage:
#   docker compose --env-file .env.deploy up -d
# ══════════════════════════════════════════════════════════════════════════════

# ── Compose project name (prefixes container/volume names) ────────────────────
COMPOSE_PROJECT_NAME=groweasy

# ── Port Mappings ─────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=3001
OLLAMA_PORT=11434

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── Ollama Configuration ──────────────────────────────────────────────────────
# Inside Docker network, backend reaches Ollama via its service name.
# Do NOT change this unless you move Ollama outside of compose.
OLLAMA_BASE_URL=http://ollama:11434/v1

# Model to use — must be pulled into the ollama container first:
#   docker compose exec ollama ollama pull llama3.2
AI_MODEL=llama3.2
AI_MAX_TOKENS=16000
AI_BATCH_SIZE=5
AI_MAX_RETRIES=3

# ── File Upload (Backend) ─────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# ── Frontend API URL (baked into Next.js build) ───────────────────────────────
# Use the HOST's address since this is accessed by the user's browser, not Docker.
# For local machine: http://localhost:3001/api
# For a VPS with domain: https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api
