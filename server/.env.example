# ══════════════════════════════════════════════════════════════════════════════
# GrowEasy AI CSV Importer — Server Environment Example
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ══════════════════════════════════════════════════════════════════════════════
# AI PROVIDER — choose ONE of the two options below
# ══════════════════════════════════════════════════════════════════════════════

# ── OPTION A: Ollama (local, free, no internet required) ─────────────────────
# 1. Install Ollama:  https://ollama.com/download
# 2. Pull a model:    ollama pull llama3.2
# 3. Ollama runs at   http://localhost:11434  by default (OpenAI-compatible at /v1)
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── OPTION B: Groq (cloud, free tier, fast) ───────────────────────────────────
# 1. Get a free API key at: https://console.groq.com
# 2. Set OLLAMA_BASE_URL to the Groq base URL
# 3. Set AI_MODEL to a Groq-supported model (see below)
# OLLAMA_BASE_URL=https://api.groq.com/openai/v1
# GROQ_API_KEY=your-groq-api-key-here   # used as the OpenAI client's apiKey

# ══════════════════════════════════════════════════════════════════════════════
# AI MODEL CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# Ollama models (pull first: ollama pull <model>):
#   llama3.2        — 2 GB  — recommended default
#   llama3.1:8b     — 4.7 GB — more accurate
#   mistral         — 4.1 GB — strong instruction following
#   qwen2.5:7b      — 4.4 GB — excellent JSON output
#
# Groq models (no download needed):
#   llama-3.3-70b-versatile   — powerful, fast
#   llama-3.1-8b-instant      — ultra-fast, lower latency
#   mixtral-8x7b-32768        — great context window
AI_MODEL=llama3.2

# Max output tokens — keep high for large batches
AI_MAX_TOKENS=16000

# Rows sent to AI per call — 5-10 recommended for local, up to 50 for cloud
AI_BATCH_SIZE=5

# Retry attempts on AI failure
AI_MAX_RETRIES=3

# ── File Upload ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
