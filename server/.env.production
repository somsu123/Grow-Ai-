# ══════════════════════════════════════════════════════════════════════════════
# GrowEasy AI CSV Importer — Backend Production Environment
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env when deploying.
# Keep this file OUT of version control if you add secrets (already in .gitignore).

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Ollama (Local LLM — no API key needed) ────────────────────────────────────
# When running with docker-compose, Ollama is a sibling container named "ollama".
# The OpenAI-compatible endpoint is at /v1.
OLLAMA_BASE_URL=http://ollama:11434/v1

# If running Ollama on the HOST machine (outside Docker), use:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# If running without Docker (bare-metal / VPS), use:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── AI Model ──────────────────────────────────────────────────────────────────
# Recommended models (pull with: ollama pull <model>):
#   llama3.2        — 2 GB  — fast, great for structured JSON extraction
#   llama3.1:8b     — 4.7 GB — more accurate, needs ≥8 GB RAM
#   mistral         — 4.1 GB — strong at instruction following
#   qwen2.5:7b      — 4.4 GB — excellent multilingual + JSON output
#   phi3.5          — 2.2 GB — very fast, lower RAM
AI_MODEL=llama3.2

# Max output tokens — keep high for large CSV batches
AI_MAX_TOKENS=16000

# Rows sent to AI per batch — lower = more reliable JSON, higher = faster
# Recommended: 5-10 for local Ollama models
AI_BATCH_SIZE=5

# How many times to retry a failed AI call before giving up
AI_MAX_RETRIES=3

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
