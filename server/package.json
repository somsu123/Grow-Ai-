{
  "name": "groweasy-csv-importer-server",
  "version": "1.0.0",
  "description": "AI-powered CSV importer backend for GrowEasy CRM",
  "main": "dist/server.js",
  "scripts": {
    "build": "cd ../app && npx tsc -p ../server/tsconfig.json",
    "start": "cd ../app && npx tsx ../server/src/server.ts",
    "dev": "cd ../app && npx tsx watch ../server/src/server.ts",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "test": "jest --config jest.config.json",
    "test:coverage": "jest --config jest.config.json --coverage"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.57.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.5.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
